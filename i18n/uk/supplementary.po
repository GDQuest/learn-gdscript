#~ msgid "The cell position of the robot on the board. [code]Vector2(0, 0)[/code] is the square cell in the top left of the board."
#~ msgstr "Положення комірки з роботом на дошці. [code]Vector2(0, 0)[/code] — це квадратна комірка в лівому верхньому кутку дошки."

#~ msgid "Creates a list of numbers from [code]0[/code] to [code]length - 1[/code]."
#~ msgstr "Створює список чисел від [code]0[/code] до [code]length - 1[/code]."

#~ msgid "Orders the robot to play an animation."
#~ msgstr "Наказує роботу відтворити анімацію."

#~ msgid "Selects units in the cell coordinates passed as the function's argument."
#~ msgstr "Вибирає юнітів у комірці, координати якої дорівнюють аргументам функції."

#~ msgid "Queues a move animation towards the target cell."
#~ msgstr "Ставить у чергу анімацію руху до цільової комірки."

#~ msgid "Adds the value passed as an argument at the back of the array."
#~ msgstr "Додає значення, передане як аргумент, наприкінці масиву."

#~ msgid "Removes the first value from the array and returns it."
#~ msgstr "Вилучає перше значення з масиву та повертає його."

#~ msgid "Removes the last value from the array and returns it."
#~ msgstr "Вилучає останнє значення з масиву та повертає його."

#~ msgid "Returns the argument converted into a [code]String[/code]. Works with the majority of value types."
#~ msgstr "Повертає аргумент, перетворений на рядок [code]String[/code]. Працює зі значеннями більшості типів."

#~ msgid "Returns the argument converted into an [code]int[/code] (whole number) [i]if possible[/i]. Supports converting decimal numbers, strings, and booleans. Useful to convert player text input into numbers."
#~ msgstr "Повертає аргумент, перетворений на [code]int[/code] (ціле число) [i]якщо таке перетворення можливе[/i]. Підтримує перетворення десяткових дробів, рядків та логічних значень. Корисно для перетворення тексту, введеного гравцем, на числа."

#~ msgid "Creates a new unit matching the type parameter and places it at the desired cell position on the game grid."
#~ msgstr "Створює новий юніт, відповідний параметру типу, і поміщає його в потрібну комірку ігрової сітки."

#~ msgid "Creates a new item and displays it in the inventory."
#~ msgstr "Створює новий предмет та показує його в інвентарі."

#~ msgid "Increases the item count by amount."
#~ msgstr "Збільшує кількість предметів на amount."

#~ msgid "Realigns the train track with the path. Select a train track in the tracks array by index to pass it as an argument."
#~ msgstr "Вирівнює залізничну колію зі шляхом. Виберіть залізничну колію в масиві tracks за індексом, щоб передати її як аргумент."

#~ msgid "If you want to assign a value to a variable, double-check that what you have on the left side of the = sign is a variable and not a function."
#~ msgstr "Якщо ви хочете надати значення змінній, двічі перевірте, що ліворуч від знака = зазначено змінну, а не функцію."

#~ msgid "You also need to ensure the syntax is correct. For example, there shouldn't be parentheses on the left side of the equal sign."
#~ msgstr "Також необхідно переконатись у правильності синтаксису. Наприклад, ліворуч від знака рівності не повинно бути круглих дужок."

#~ msgid "In the case of a condition, ensure that you are using two equal signs to check for equality (==)."
#~ msgstr "Якщо ж це умова, то переконайтеся, що для перевірки рівності використано два знаки дорівнює (==)."
