#~ msgid "Add to the function so the character's health is never greater than [code]80[/code]."
#~ msgstr "បន្ថែមទៅក្នុង func ដើម្បីឱ្យ health(ឈាម) របស់តួអង្គមិនដែលលើសពី [code]80[/code]។"

#~ msgid "When the robot takes damage, its health can be negative."
#~ msgstr "នៅពេលដែល robot រងការខូចខាត health(ឈាម) របស់វាអាចក្លាយជា អវិជ្ជមាន។"

#~ msgid "We might want to display the health number on screen, like in Japanese RPGs."
#~ msgstr "យើងអាចចង់បង្ហាញលេខ health(ឈាម) លើអេក្រង់ ដូចក្នុង​ Game RPG ជប៉ុន។"

#~ msgid "We don't want negative numbers. We want to stop at zero instead."
#~ msgstr "យើងមិនចង់បានលេខ អវិជ្ជមានទេ។ យើងចង់ឈប់ត្រឹមសូន្យ ជំនួសវិញ។"

#~ msgid "Calling the function should reduce [code]health[/code] by [code]amount[/code]."
#~ msgstr "ការហៅ func គួរតែបន្ថយ [code]health(ឈាម)[/code] ដោយ [code]amount[/code]។"

#~ msgid "Our robot's health is always between [code]0[/code] and [code]100[/code]."
#~ msgstr "ឈាម របស់ robot យើងគឺស្ថិតនៅចន្លោះ [code]0[/code] និង [code]100[/code] ជានិច្ច។"

#~ msgid "But as our robot fights, we want to increase its strength and toughness."
#~ msgstr "ប៉ុន្តែនៅពេលដែល robot របស់យើងប្រយុទ្ធ យើងចង់ បង្កើនកម្លាំង និងភាពធន់របស់វា។"

#~ msgid "When a character levels up, it might deal more damage to enemies, gain new abilities or, in our case, gain more health."
#~ msgstr "នៅពេលដែលតួអង្គ ឡើងកម្រិត (level up) វាអាចនឹងធ្វើឱ្យសត្រូវ រងការខូចខាតកាន់តែច្រើន, ហើយទទួលបាន​ សមត្ថភាពថ្មី ឬក្នុងករណីរបស់យើង គឺទទួលបាន ឈាមកាន់តែច្រើន។"

#~ msgid "Our robot has decided to stand at the top of the board."
#~ msgstr "robot របស់យើងបានសម្រេចចិត្តឈរនៅផ្នែកខាងលើនៃក្តារ។"

#~ msgid "Complete the [code]move_to_bottom()[/code] function so the robot moves to the bottom of the board."
#~ msgstr "បំពេញ func [code]move_to_bottom()[/code] ដើម្បីឱ្យ​ robot ផ្លាស់ទីទៅផ្នែកខាងក្រោមនៃក្តារ។"

