#~ msgstr "array គួរមានតម្លៃចំនួនបី ដើម្បីឱ្យ Robot វាយបីដង ៖ វាយពីរដងដោយ jab តាមដោយ uppercut មួយដង។"

#~ msgid "[code]degrees = radians * 180 / PI[/code]"
#~ msgstr "[code]degrees = radians * 180 / PI[/code]"

#~ msgid "[code]show()[/code]"
#~ msgstr "[code]show()[/code]"

