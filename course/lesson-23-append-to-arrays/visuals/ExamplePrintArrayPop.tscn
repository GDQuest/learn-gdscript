[sub_resource type="GDScript" id="1"]
script/source = "extends OutputConsole

signal coroutine_step_requested
signal coroutine_finished

@onready var crates = [\"sword\", \"shield\", \"gems\"]


func run():
	emit_signal(\"line_highlight_requested\", 2)
	await coroutine_step_requested
	crates.pop_back()
	emit_signal(\"line_highlight_requested\", 3)
	await coroutine_step_requested
	print_output([crates])
	emit_signal(\"line_highlight_requested\", 4)
	await coroutine_step_requested
	coroutine_finished.emit()


func reset():
	clear_messages()
	crates = [\"sword\", \"shield\", \"gems\"]
"

