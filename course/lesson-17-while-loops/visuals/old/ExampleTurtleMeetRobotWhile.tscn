[sub_resource type="GDScript" id="1"]
script/source = "extends Node2D

var size := 40.0

@export var _turtle: DrawingTurtle
@export var _robot: Node2D
@onready var _robot_animation_tree := find_child(\"AnimationTree\")

func run():
	_turtle.reset()
	_turtle.position = Vector2(-110, 110)
	var number = 0
	while number < 3:
		_turtle.jump(110, 0)
		draw_square()
		number += 1

	_turtle.play_draw_animation()
	var rect: Rect2 = _turtle.get_rect()
	_turtle.position = - rect.size / 2.0
	
	await _turtle.turtle_finished
	_robot_animation_tree.travel(\"damage\")
	await _robot_animation_tree.animation_finished
	_robot_animation_tree.travel(\"idle\")


func draw_square():
	_turtle.move_forward(100)
	_turtle.turn_right(90)
	_turtle.move_forward(100)
	_turtle.turn_right(90)
	_turtle.move_forward(100)
	_turtle.turn_right(90)
	_turtle.move_forward(100)
	_turtle.turn_right(90)
"

