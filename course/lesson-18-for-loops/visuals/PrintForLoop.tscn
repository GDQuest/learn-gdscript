[sub_resource type="GDScript" id="1"]
script/source = "extends OutputConsole

signal coroutine_step_requested
signal coroutine_finished

@onready var number = RunnableCodeExampleDebugger.UNINITIALIZED_VARIABLE_VALUE

func run() -> void:
	emit_signal(\"line_highlight_requested\", 0)
	await coroutine_step_requested
	for _number in range(3):
		emit_signal(\"line_highlight_requested\", 1)
		number = _number
		await coroutine_step_requested
		print_output([_number])
		emit_signal(\"line_highlight_requested\", 2)
		await coroutine_step_requested
	coroutine_finished.emit()


func reset() -> void:
	clear_messages()
	number = RunnableCodeExampleDebugger.UNINITIALIZED_VARIABLE_VALUE
"

