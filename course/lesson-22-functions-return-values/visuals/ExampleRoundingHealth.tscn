[sub_resource type="GDScript" id="2"]
script/source = "
@tool
extends RunnableCodeExample


func _ready():
	super._ready()
	_scene_instance.health_slider = await create_slider_for(\"health\", 0.0, 100.0, 0.1)
"

[sub_resource type="GDScript" id="3"]
script/source = "extends PanelContainer

var initial_health := 100.0
var health := initial_health: set = set_health
var health_slider: HSlider

@onready var label := $Label as Label


func set_health(new_value: float):
	health = new_value
	if not label:
		await self.ready
	label.text = \"Health: %s\" % round(health)


func reset() -> void:
	self.health = initial_health
	health_slider.value = initial_health
"

