[node name="ErrorLabel" parent="MarginContainer/Column" parent_id_path=PackedInt32Array(2038824587) index="0" unique_id=1311160456]
text = "The identifier \"angular_speed\" isn't declared in the current scope (at line 6)."

[node name="Value" parent="MarginContainer/Column/Content/ErrorExplanation" parent_id_path=PackedInt32Array(577124066) index="1" unique_id=564563128]
text = "The [code]set_angular_speed()[/code] function can't use the [code]angular_speed[/code] variable because it isn't script-wide. It also isn't in the [code]set_angular_speed()[/code] function."

[node name="Value" parent="MarginContainer/Column/Content/ErrorSuggestion" parent_id_path=PackedInt32Array(430840361) index="1" unique_id=417247627]
text = "Make sure you define the [code]angular_speed[/code] variable in the [code]set_angular_speed()[/code] function, or define it outside of functions so it's script-wide."

[node name="NoContent" parent="MarginContainer/Column" parent_id_path=PackedInt32Array(2038824587) index="3" unique_id=1738366945]
text = "Sorry, we don't have this particular error message covered yet!

