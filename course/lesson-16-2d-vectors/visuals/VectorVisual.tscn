[sub_resource type="GDScript" id="1"]
script/source = "extends Node2D

@export var _label: Label
@export var _label_x: Label
@export var _label_y: Label
@export var _triangle_x: Sprite2D
@export var _triangle_y: Sprite2D
@export var _color_rect: ColorRect
@export var _triangle_mouse: Sprite2D

@export var size := Vector2(300, 300)

var touch_down := Vector2.ZERO
var vector :=- Vector2.ZERO


func _ready():
	_color_rect.size = size
	_color_rect.position = -size/2
	_label_y.position.y = size.y/2
	_label_x.position.x = size.x/2 + 10
	_triangle_x.position = Vector2(size.x/2, 0)
	_triangle_y.position = Vector2(0, size.y/2)
	queue_redraw()


func _process(_delta: float) -> void:
	vector = get_local_mouse_position().limit_length(160)
	_triangle_mouse.position = vector
	_triangle_mouse.rotation = Vector2.RIGHT.angle_to(vector)
	_label.text = \"Vector2%s\" % [vector.round()]
	queue_redraw()


func _draw():
	draw_line(Vector2(0, -size.y/2), Vector2(0, size.y/2), Color.GRAY, 2)
	draw_line(Vector2(-size.x/2, 0), Vector2(size.x/2, 0), Color.GRAY, 2)
	draw_line(Vector2.ZERO, vector, Color.WHITE, 2)
	
"

