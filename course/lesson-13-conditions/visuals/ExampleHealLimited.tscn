[sub_resource type="GDScript" id="1"]
script/source = "extends Node2D

signal line_highlight_requested(line)

@export var start_health := 75
@export var max_health := 100
@export var health_gained = 50
var health := start_health

@onready var _health_bar := find_child(\"HealthBar\")
@onready var _animation_tree := find_child(\"AnimationTree\")


func _ready() -> void:
	await get_tree().process_frame
	reset()


func reset() -> void:
	health = start_health
	_health_bar.set_health(health) 


func run_coroutine(coroutine_controller: CoroutineController):
	health = start_health
	_health_bar.set_health(health)
	emit_signal(\"line_highlight_requested\", 0)
	await coroutine_controller.step_requested
	
	health += health_gained
	_animation_tree.travel(\"heal\")
	_health_bar.set_health(health)
	emit_signal(\"line_highlight_requested\", 1)
	await coroutine_controller.step_requested
	
	emit_signal(\"line_highlight_requested\", 2)
	await coroutine_controller.step_requested
	
	if health > max_health:
		health = max_health
		_health_bar.set_health(health)
		emit_signal(\"line_highlight_requested\", 3)
		await coroutine_controller.step_requested
	
	_health_bar.set_health(health)
	coroutine_controller.finished.emit()
"

