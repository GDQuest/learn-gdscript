[sub_resource type="GDScript" id="1"]
script/source = "extends Node2D

var do_draw := false


func _draw() -> void:
	if do_draw:
		draw_circle(Vector2.ZERO, 60.0, Color.AQUA)


func run() -> void:
	do_draw = true
	queue_redraw()


func reset() -> void:
	do_draw = false
	queue_redraw()
"

