[sub_resource type="Shader" id="24"]
code = "shader_type canvas_item;
render_mode blend_add;

uniform float thickness = 1.0;

void vertex() {
    VERTEX.x *= (1.0 - INSTANCE_CUSTOM.y) * 2.0;
		VERTEX.y *= thickness;
}"

